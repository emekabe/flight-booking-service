# ─── Database ─────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/flight_booking_db
DB_USERNAME=flight_user
DB_PASSWORD=your_db_password_here

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# ─── Default Tenant Bootstrap (seeded on first startup) ──────────────────────
DEFAULT_TENANT_CODE=DEFAULT
DEFAULT_TENANT_NAME=Default Airline
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
